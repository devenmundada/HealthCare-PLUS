{
  "name": "healthcare-backend",
  "version": "1.0.0",
  "description": "Healthcare AI Platform Backend",
  "main": "server.js",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "nodemon --exec ts-node src/app.ts",
    "start:ts": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start:prod": "NODE_ENV=production node server.js",
    "migration:generate": "npm run typeorm migration:generate -- -d src/config/data-source.ts",
    "migration:run": "npm run typeorm migration:run -- -d src/config/data-source.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d src/config/data-source.ts",
    "typeorm": "ts-node-dev ./node_modules/typeorm/cli",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "security:scan": "npm audit",
    "docker:build": "docker build -t healthcare-api .",
    "docker:run": "docker-compose up -d",
    "db:setup": "npx ts-node scripts/setup-database.ts",
    "db:check": "node scripts/check-db.js",
    "db:migrate": "npm run typeorm migration:run -- -d src/config/data-source.ts",
    "db:generate": "npm run typeorm migration:generate -- -d src/config/data-source.ts",
    "db:seed": "node scripts/seed-demo-users.js",
    "db:fix-password": "node scripts/fix-patient-password.js",
    "google-auth": "ts-node src/scripts/get-google-refresh-token.ts",
    "build": "tsc"
  },
  "keywords": [
    "healthcare",
    "ai",
    "nodejs",
    "mysql",
    "medical",
    "hipaa"
  ],
  "author": "HealthCare+ Team",
  "license": "ISC",
  "dependencies": {
    "argon2": "^0.30.3",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "dicom-parser": "^1.8.21",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.6.1",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.1",
    "googleapis": "^170.1.0",
    "helmet": "^7.2.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.16.0",
    "node-cron": "^3.0.3",
    "node-forge": "^1.3.1",
    "nodemailer": "^8.0.1",
    "ollama": "^0.6.3",
    "pg": "^8.19.0",
    "pg-pool": "^3.10.1",
    "prom-client": "^14.2.0",
    "python-shell": "^5.0.0",
    "redis": "^4.6.7",
    "reflect-metadata": "^0.1.14",
    "socket.io": "^4.8.3",
    "socket.io-redis": "^5.4.0",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.12.2",
    "typeorm": "^0.3.28",
    "uuid": "^9.0.1",
    "winston": "^3.9.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.33",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/socket.io": "^3.0.1",
    "@types/speakeasy": "^2.0.9",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/twilio": "^3.19.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.42.0",
    "jest": "^29.5.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
