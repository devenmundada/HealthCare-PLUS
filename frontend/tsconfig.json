{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Node",

    "jsx": "react-jsx",

    "strict": false,
    "skipLibCheck": true,

    "noEmit": true,
    "isolatedModules": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}
